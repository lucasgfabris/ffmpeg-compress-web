{
  "name": "ffmpeg-compress-web",
  "version": "1.0.0",
  "description": "Aplicação web para comprimir e converter vídeos usando FFmpeg",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"*.js\" \"public/**/*.js\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "fluent-ffmpeg": "^2.1.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.4.2"
  },
  "keywords": ["video", "converter", "ffmpeg", "compression"],
  "author": "",
  "license": "MIT"
}
